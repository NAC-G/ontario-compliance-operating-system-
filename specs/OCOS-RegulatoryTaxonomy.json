  "rules": {
    "auto_severity_escalation": [
      {
        "if_tag_in": ["WAH-3M", "ELEC-EXPOSED", "MOL-ORDER", "INC-INJURY"],
        "then_severity_min": "High",
        "then_status": "Hazard - Open"
      }
    ],
    "report_inclusion": {
      "toolbox_talk": ["TBT-DELIVERED", "TBT-SIGNOFF", "competency:*"],
      "jhsc_inspection": ["JHSC-WALK", "JHSC-RECOMMENDATION", "*"],
      "incident_report": ["INC-INJURY", "INC-PROPERTY", "INC-NEAR-MISS", "MOL-ORDER"],
      "daily_log": ["*"]
    },
    "notification_triggers": [
      {
        "tag": "INC-INJURY",
        "action": "Show OHSA s.51/52 notification helper. If critical injury or fatality, surface MOL contact + Section 51 24-hour written report template."
      },
      {
        "tag": "MOL-ORDER",
        "action": "Lock site to admin-only edits. Surface compliance deadline tracker."
      }
    ]
  },
  "competency_certifications": {
    "WAH": { "regulation": "OReg_297_13", "cycle_years": 3 },
    "WHMIS": { "regulation": "OReg_860", "cycle_years": 1, "note": "Annual review of training is good practice; not a hard re-cert under OReg 860 itself." },
    "Confined_Space": { "regulation": "OReg_632_05", "cycle_years": 3 },
    "First_Aid": { "regulation": "WSIA Reg 1101", "cycle_years": 3 },
    "Lift_Truck": { "regulation": "CSA B335", "cycle_years": 3 }
  },
  "notes_for_implementer": [
    "This file is the source of truth for the in-app tag picker. UI surfaces categories first, then tags within.",
    "Tag IDs are stable. Never rename — add new tags and deprecate old ones via an `active: false` flag in v1.1+.",
    "When a photo gets a tag, OHSA References on the FC-Photos record auto-fill from this file.",
    "Severity defaults can be overridden by user; record both the default and the override.",
    "On every taxonomy version bump, log to the Generator Update Log per the T2 pattern.",
    "Consult an Ontario H&S professional before final publication — taxonomy is informational, not legal advice."
  ],
  "disclaimer": "This taxonomy is a documentation aid. It does not constitute legal advice. Operators retain responsibility for confirming current OHSA / O.Reg requirements and for compliance with all applicable Ontario workplace health and safety laws."
}
