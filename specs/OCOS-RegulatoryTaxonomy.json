  "jurisdiction": "Ontario, Canada",
  "last_reviewed": "2026-04",
  "review_frequency_months": 6,
  "regulatory_anchors": {
    "OHSA": "Occupational Health and Safety Act, R.S.O. 1990, c. O.1",
    "OReg_213_91": "O. Reg. 213/91 — Construction Projects",
    "OReg_297_13": "O. Reg. 297/13 — Working at Heights Training",
    "OReg_420_21": "O. Reg. 420/21 — Notices and Reports",
    "OReg_632_05": "O. Reg. 632/05 — Confined Spaces",
