{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "PWA — OCOS Field (static)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000", "--directory", "pwa"],
      "port": 3000
